---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/posts', label: 'Posts' },
  { href: '/categories', label: 'Categories' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-50">
  <nav class="w-full max-w-7xl mx-auto px-6 lg:px-10 h-14 flex items-center justify-between">
    <a href="/" class="font-bold text-gray-900 hover:text-gray-600 transition-colors text-lg tracking-tight">
      Pat Keenan
    </a>
    <div class="flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm transition-colors ${
            currentPath.startsWith(href)
              ? 'text-gray-900 font-semibold'
              : 'text-gray-500 hover:text-gray-900'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href="/search"
        class={`text-sm transition-colors ${
          currentPath.startsWith('/search')
            ? 'text-gray-900'
            : 'text-gray-400 hover:text-gray-700'
        }`}
        title="Search"
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
        </svg>
      </a>
      <a
        href="/rss.xml"
        class="text-gray-400 hover:text-gray-600 transition-colors"
        title="RSS Feed"
        aria-label="RSS Feed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm1.5 2.5c5.523 0 10 4.477 10 10a1 1 0 1 1-2 0 8 8 0 0 0-8-8 1 1 0 0 1 0-2m0 4a6 6 0 0 1 6 6 1 1 0 1 1-2 0 4 4 0 0 0-4-4 1 1 0 0 1 0-2m.5 7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
