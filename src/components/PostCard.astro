---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, date } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group border-t border-gray-100 py-5">
  <a href={`/posts/${post.id}`} class="block">
    <h2 class="font-semibold text-gray-900 line-clamp-2 text-sm leading-snug mb-1.5 group-hover:text-gray-500 transition-colors">
      {title}
    </h2>
    <time class="font-mono text-[11px] text-gray-400 block mb-2" datetime={date.toISOString()}>
      {formattedDate}
    </time>
    <p class="text-xs text-gray-500 line-clamp-3 leading-relaxed">
      {description}
    </p>
  </a>
</article>
