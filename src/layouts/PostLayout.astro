---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, date, category, tags } = post.data;
const categorySlug = category.toLowerCase().replace(/\s+/g, '-');

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} ogType="article">
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight mb-3">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <a
          href={`/categories/${categorySlug}`}
          class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-2 py-1 rounded transition-colors font-medium"
        >
          {category}
        </a>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="prose prose-gray max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
