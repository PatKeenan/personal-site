---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const leadPost = sortedPosts[0];
const gridPosts = sortedPosts.slice(1);

// Topics: count posts per tag and category
const tagCounts: Record<string, number> = {};
const categoryCounts: Record<string, number> = {};
for (const post of allPosts) {
  categoryCounts[post.data.category] = (categoryCounts[post.data.category] || 0) + 1;
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  }
}
const sortedTopics = Object.entries(tagCounts).sort(([, a], [, b]) => b - a);

// Writing stats
const totalPosts = allPosts.length;
const totalCategories = Object.keys(categoryCounts).length;
const totalTags = Object.keys(tagCounts).length;

// Archive: group by month
const archiveMap: Record<string, number> = {};
for (const post of allPosts) {
  const key = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
  archiveMap[key] = (archiveMap[key] || 0) + 1;
}
const archive = Object.entries(archiveMap)
  .sort(([a], [b]) => new Date(b).valueOf() - new Date(a).valueOf())
  .slice(0, 6);

// Activity heatmap: last 52 weeks
const today = new Date();
const yearAgo = new Date(today);
yearAgo.setFullYear(today.getFullYear() - 1);

// Bucket posts by ISO week key YYYY-Www
function isoWeekKey(d: Date) {
  const dt = new Date(Date.UTC(d.getFullYear(), d.getMonth(), d.getDate()));
  const day = dt.getUTCDay() || 7;
  dt.setUTCDate(dt.getUTCDate() + 4 - day);
  const yearStart = new Date(Date.UTC(dt.getUTCFullYear(), 0, 1));
  const weekNum = Math.ceil((((dt.valueOf() - yearStart.valueOf()) / 86400000) + 1) / 7);
  return `${dt.getUTCFullYear()}-W${String(weekNum).padStart(2, '0')}`;
}

const postCountByWeek: Record<string, number> = {};
for (const post of allPosts) {
  const key = isoWeekKey(post.data.date);
  postCountByWeek[key] = (postCountByWeek[key] || 0) + 1;
}

// Build 52-week grid (newest last)
const weeks: { key: string; count: number }[] = [];
const cursor = new Date(yearAgo);
cursor.setDate(cursor.getDate() - cursor.getDay()); // align to Sunday
while (cursor <= today) {
  const key = isoWeekKey(cursor);
  weeks.push({ key, count: postCountByWeek[key] || 0 });
  cursor.setDate(cursor.getDate() + 7);
}

const leadDate = leadPost?.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Pat Keenan"
  description="Software engineer. Writing about code, tools, and the web."
>
  <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr_200px] gap-8 xl:gap-12">

    <!-- ===== LEFT SIDEBAR ===== -->
    <aside class="lg:sticky lg:top-24 lg:self-start space-y-8">

      <!-- About -->
      <div>
        <div class="w-14 h-14 rounded-full bg-gray-200 flex items-center justify-center text-gray-400 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
          </svg>
        </div>
        <p class="font-bold text-gray-900 text-sm mb-1">Pat Keenan</p>
        <p class="text-xs text-gray-500 leading-relaxed mb-2">
          Software engineer writing about code, tools, and the web.
        </p>
        <a href="/about" class="text-xs text-accent-teal hover:opacity-80 transition-opacity">Read more →</a>
        <div class="flex items-center gap-3 mt-3">
          <a href="https://linkedin.com/in/patkeenan" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent-teal transition-colors" title="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
            </svg>
          </a>
          <a href="https://github.com/patkeenan" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-accent-teal transition-colors" title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
          </a>
          <a href="/rss.xml" class="text-gray-400 hover:text-accent-teal transition-colors" title="RSS">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm1.5 2.5c5.523 0 10 4.477 10 10a1 1 0 1 1-2 0 8 8 0 0 0-8-8 1 1 0 0 1 0-2m0 4a6 6 0 0 1 6 6 1 1 0 1 1-2 0 4 4 0 0 0-4-4 1 1 0 0 1 0-2m.5 7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Topics -->
      <div>
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-3">Topics</h2>
        <ul class="space-y-1.5">
          {sortedTopics.map(([tag, count]) => (
            <li>
              <a
                href={`/tags/${tag}`}
                class="flex items-center justify-between text-xs text-gray-600 hover:text-accent-teal transition-colors group"
              >
                <span class="group-hover:underline">#{tag}</span>
                <span class="font-mono text-gray-500">{count}</span>
              </a>
            </li>
          ))}
        </ul>
        <div class="mt-3 pt-3 border-t border-gray-100">
          <a href="/categories" class="text-xs text-accent-teal hover:opacity-80 transition-opacity">
            All categories →
          </a>
        </div>
      </div>

    </aside>

    <!-- ===== CENTER COLUMN ===== -->
    <div class="min-w-0">

      {leadPost && (
        <!-- Lead Story -->
        <section class="mb-8 pb-8 border-b border-gray-200">
          <p class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-3">Lead Story</p>
          <a href={`/posts/${leadPost.id}`} class="group block mb-3">
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight line-clamp-2 group-hover:text-gray-600 transition-colors">
              {leadPost.data.title}
            </h1>
          </a>
          <time class="font-mono text-xs text-gray-400 block mb-3" datetime={leadPost.data.date.toISOString()}>
            {leadDate}
          </time>
          <p class="text-sm text-gray-600 leading-relaxed line-clamp-3 mb-4">
            {leadPost.data.description}
          </p>
          <div class="flex items-center gap-4">
            <a href={`/posts/${leadPost.id}`} class="text-xs text-accent-teal hover:opacity-80 transition-opacity">
              Read more →
            </a>
            <span class="text-xs text-gray-300">|</span>
            <span class="text-xs text-gray-400 font-mono">{leadPost.data.category}</span>
          </div>
        </section>
      )}

      <!-- Post Grid -->
      {gridPosts.length > 0 && (
        <section class="mb-10">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink">Recent Posts</h2>
            <a href="/posts" class="text-xs text-accent-teal hover:opacity-80 transition-opacity">
              All posts →
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-0">
            {gridPosts.map((post) => {
              const d = post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
              return (
                <article class="group py-5 pr-4">
                  <a href={`/posts/${post.id}`} class="block">
                    <h3 class="font-semibold text-gray-900 line-clamp-2 text-sm leading-snug mb-1.5 group-hover:text-accent-teal transition-colors">
                      {post.data.title}
                    </h3>
                    <time class="font-mono text-[11px] text-gray-400 block mb-2" datetime={post.data.date.toISOString()}>
                      {d}
                    </time>
                    <p class="text-xs text-gray-500 line-clamp-3 leading-relaxed">
                      {post.data.description}
                    </p>
                  </a>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Activity Heatmap -->
      <section class="border-t border-gray-100 pt-6">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-4">Writing Activity</h2>
        <div class="flex flex-wrap gap-[3px]">
          {weeks.map(({ count }) => (
            <div
              class={`w-[10px] h-[10px] rounded-sm flex-shrink-0 ${
                count === 0
                  ? 'bg-gray-100'
                  : count === 1
                  ? 'bg-gray-400'
                  : 'bg-gray-800'
              }`}
              title={count > 0 ? `${count} post${count > 1 ? 's' : ''}` : 'No posts'}
            />
          ))}
        </div>
        <p class="text-[10px] text-gray-400 mt-2 font-mono">Past 52 weeks · {totalPosts} total posts</p>
      </section>

    </div>

    <!-- ===== RIGHT SIDEBAR ===== -->
    <aside class="lg:sticky lg:top-24 lg:self-start space-y-8">

      <!-- Stats -->
      <div>
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-3">Writing</h2>
        <ul class="space-y-2">
          <li class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Posts</span>
            <span class="font-mono text-xs text-gray-700 font-semibold">{totalPosts}</span>
          </li>
          <li class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Categories</span>
            <span class="font-mono text-xs text-gray-700 font-semibold">{totalCategories}</span>
          </li>
          <li class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Tags</span>
            <span class="font-mono text-xs text-gray-700 font-semibold">{totalTags}</span>
          </li>
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-3">Categories</h2>
        <ul class="space-y-1.5">
          {Object.entries(categoryCounts).sort(([,a],[,b]) => b - a).map(([cat, count]) => (
            <li>
              <a
                href={`/categories/${encodeURIComponent(cat.toLowerCase().replace(/\s+/g, '-'))}`}
                class="flex items-center justify-between text-xs text-gray-600 hover:text-accent-teal transition-colors group"
              >
                <span class="group-hover:underline">{cat}</span>
                <span class="font-mono text-gray-400">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Archive -->
      {archive.length > 0 && (
        <div>
          <h2 class="text-[10px] font-bold uppercase tracking-widest text-accent-pink mb-3">Archive</h2>
          <ul class="space-y-1.5">
            {archive.map(([month, count]) => (
              <li class="flex items-center justify-between">
                <span class="text-xs text-gray-600">{month}</span>
                <span class="font-mono text-[11px] text-gray-400">{count}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

    </aside>

  </div>
</BaseLayout>
