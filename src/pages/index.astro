---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = sortedPosts.slice(0, 2);
const remainingPosts = sortedPosts.slice(2);

// Group remaining posts by category
const byCategory: Record<string, typeof remainingPosts> = {};
for (const post of remainingPosts) {
  const cat = post.data.category;
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(post);
}
const categoryGroups = Object.entries(byCategory).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout
  title="Pat Keenan"
  description="Software engineer. Writing about code, tools, and the web."
>
  <!-- Bio Section -->
  <section class="mb-12 pb-10 border-b border-gray-200">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
      <div class="w-20 h-20 rounded-full bg-gray-200 flex-shrink-0 overflow-hidden flex items-center justify-center text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16">
          <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
          <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
        </svg>
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-bold text-gray-900 mb-1">Pat Keenan</h1>
        <p class="text-gray-500 mb-3 max-w-lg">
          Software engineer. I write about building software, tools I find useful, and whatever else captures my attention.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="https://linkedin.com/in/patkeenan"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-blue-600 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href="https://github.com/patkeenan"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-gray-900 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
            GitHub
          </a>
          <a
            href="/rss.xml"
            class="inline-flex items-center gap-1.5 text-sm text-gray-600 hover:text-orange-500 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zm1.5 2.5c5.523 0 10 4.477 10 10a1 1 0 1 1-2 0 8 8 0 0 0-8-8 1 1 0 0 1 0-2m0 4a6 6 0 0 1 6 6 1 1 0 1 1-2 0 4 4 0 0 0-4-4 1 1 0 0 1 0-2m.5 7a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/>
            </svg>
            RSS
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured / Latest Posts -->
  {featuredPosts.length > 0 && (
    <section class="mb-12">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xs font-bold uppercase tracking-widest text-gray-400">Latest</h2>
        <a href="/posts" class="text-xs text-gray-400 hover:text-gray-700 transition-colors">
          All posts &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {featuredPosts.map((post) => <PostCard post={post} featured={true} />)}
      </div>
    </section>
  )}

  <!-- Category Sections -->
  {categoryGroups.map(([category, posts]) => (
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="text-xs font-bold uppercase tracking-widest text-gray-400">{category}</h2>
        <div class="flex-1 h-px bg-gray-100"></div>
        <a
          href={`/categories/${encodeURIComponent(category.toLowerCase().replace(/\s+/g, '-'))}`}
          class="text-xs text-gray-400 hover:text-gray-700 transition-colors"
        >
          More &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  ))}
</BaseLayout>
