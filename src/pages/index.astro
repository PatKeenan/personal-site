---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout
  title="Pat Keenan"
  description="Software engineer. Writing about code, tools, and the web."
>
  <section class="mb-12">
    <h1 class="text-2xl font-bold mb-3">Pat Keenan</h1>
    <p class="text-gray-600 max-w-xl">
      Software engineer. I write about building software, tools I find useful, and whatever else captures my attention.
    </p>
  </section>

  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400">Recent Posts</h2>
      <a href="/posts" class="text-sm text-gray-500 hover:text-gray-900 transition-colors">
        All posts &rarr;
      </a>
    </div>
    {recentPosts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
