---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all unique tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Posts — Pat Keenan" description="All posts.">
  <header class="mb-8">
    <h1 class="text-2xl font-bold mb-4">Posts</h1>
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}
  </header>
  <div>
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
