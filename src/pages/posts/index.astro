---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategorySidebar from '../../components/CategorySidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Build categories list with counts and slugs
const categoryCounts: Record<string, number> = {};
for (const post of posts) {
  const cat = post.data.category;
  categoryCounts[cat] = (categoryCounts[cat] ?? 0) + 1;
}
const categories = Object.entries(categoryCounts)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, count]) => ({
    name,
    count,
    slug: name.toLowerCase().replace(/\s+/g, '-'),
  }));
---

<BaseLayout title="Posts — Pat Keenan" description="All posts.">
  <div class="flex flex-col lg:flex-row gap-10">
    <div class="flex-1 min-w-0">
      <header class="mb-8">
        <h1 class="text-2xl font-bold">Posts</h1>
      </header>
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
    <div class="lg:w-52 shrink-0">
      <CategorySidebar categories={categories} />
    </div>
  </div>
</BaseLayout>
