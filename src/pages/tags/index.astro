---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const tagCounts: Record<string, number> = {};
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
  }
}

const tags = Object.entries(tagCounts).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout title="Tags — Pat Keenan" description="All post tags.">
  <h1 class="text-2xl font-bold mb-8">Tags</h1>
  <div class="flex flex-wrap gap-3">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag}`}
        class="flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5 rounded transition-colors"
      >
        <span class="text-sm">#{tag}</span>
        <span class="text-xs text-gray-400">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>
